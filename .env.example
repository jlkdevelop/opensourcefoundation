# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

# ─── Database ────────────────────────────────────────────────────────────────
# Neon (production): copy the pooled connection string from the Neon dashboard.
# Local dev:         postgresql://postgres:postgres@localhost:5432/opensourcefoundation
DATABASE_URL="postgresql://user:password@localhost:5432/opensourcefoundation"

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=""

# GitHub OAuth app — create at https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Full public URL of this deployment (no trailing slash).
# Local: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (magic-link) ──────────────────────────────────────────────────────
# Any SMTP-compatible provider (Resend, Postmark, SES, etc.)
EMAIL_SERVER="smtp://user:password@smtp.example.com:587"
EMAIL_FROM="noreply@opensourcefoundation.dev"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
